#!/bin/zsh

SAVE_DIR="$HOME/Downloads"
WIDTH=""

# オプション (-w: 幅指定, -d: 保存先ディレクトリ指定)
while getopts "w:d:" opt; do
  case $opt in
    w) WIDTH="$OPTARG" ;;
    d) SAVE_DIR="$OPTARG" ;;
  esac
done
shift $((OPTIND - 1))

mkdir -p "$SAVE_DIR"

if [ $# -gt 0 ]; then
    FILES=("$@")
else
    setopt cshnullglob
    setopt nocaseglob
    FILES=(*.jpg *.jpeg *.png)
    unsetopt nocaseglob
    setopt cshnullglob
fi

TOTAL=${#FILES[@]}
COUNT=0

for FILE in "${FILES[@]}"; do
    [ -e "$FILE" ] || continue
    COUNT=$((COUNT + 1))
    FILENAME=$(basename "${FILE%.*}")

    if [ -n "$WIDTH" ]; then
        echo "[$COUNT/$TOTAL] Converting (Resize to ${WIDTH}px): $FILE -> $SAVE_DIR/$FILENAME.webp"
        cwebp -quiet -q 75 -m 6 -resize "$WIDTH" 0 "$FILE" -o "$SAVE_DIR/$FILENAME.webp"
    else
        echo "[$COUNT/$TOTAL] Converting (Original Size): $FILE -> $SAVE_DIR/$FILENAME.webp"
        cwebp -quiet -q 75 -m 6 "$FILE" -o "$SAVE_DIR/$FILENAME.webp"
    fi
done

echo "Done."
